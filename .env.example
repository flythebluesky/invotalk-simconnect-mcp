# Transport: "stdio" or "http"
TRANSPORT=stdio

# HTTP settings (only used when TRANSPORT=http)
PORT=8443
TLS_ENABLED=false

# Authentication (comma-separated tokens, or "disabled")
AUTH_BEARER_TOKENS=disabled

# Logging: debug, info, warn, error
LOG_LEVEL=info

# SimConnect DLL path (optional, default searches exe directory and PATH)
# SIMCONNECT_DLL_PATH=SimConnect.dll
