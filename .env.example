# Transport: "stdio" or "http"
TRANSPORT=stdio

# HTTP settings (only used when TRANSPORT=http)
PORT=8443
TLS_ENABLED=false

# Authentication (comma-separated tokens, or "disabled")
AUTH_BEARER_TOKENS=disabled

# Logging: debug, info, warn, error
LOG_LEVEL=info

# SimConnect DLL path (optional, auto-detects from MSFS SDK env vars and default paths)
# SIMCONNECT_DLL_PATH=C:\MSFS 2024 SDK\SimConnect SDK\lib\SimConnect.dll
